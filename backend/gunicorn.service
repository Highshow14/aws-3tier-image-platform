[Unit]
Description=Gunicorn Flask Application
After=network.target

[Service]
User=ec2-user
Group=ec2-user

WorkingDirectory=/opt/image-platform/backend

Environment="PATH=/opt/image-platform/backend/venv/bin"

ExecStart=/opt/image-platform/backend/venv/bin/gunicorn \
          --workers 3 \
          --bind 0.0.0.0:5000 \
          app:app

Restart=always

[Install]
WantedBy=multi-user.target